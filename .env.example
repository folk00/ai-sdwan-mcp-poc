# Public example only. Do not commit real values.

SDWAN_MOCK=true
SDWAN_BASE_URL=https://sdwan-manager.example.local
SDWAN_USERNAME=admin
SDWAN_PASSWORD=change-me
SDWAN_VERIFY_SSL=false

CML_BASE_URL=https://cml.example.local
CML_USERNAME=admin
CML_PASSWORD=change-me
CML_LAB_ID=
CML_ENABLE_MUTATION=false

APP_HOST=127.0.0.1
APP_PORT=8088

# Optional GitLab real-lab bridge. Use only in private CI/CD variables.
LAB_API_BASE_URL=https://automation-api.example.local
LAB_API_KEY=
LAB_API_KEY_HEADER=x-api-key
LAB_EDGE_LABEL=GitLab_AutomationSite
LAB_MUTATION_APPROVED=false
LAB_DRY_RUN_APPROVE=false
LAB_DRY_RUN_ENDPOINT=/api/cml/automation-edges/create
LAB_API_TIMEOUT=1200
LAB_ONBOARD_ENDPOINT=/api/sdwan/onboarding/by-label
LAB_POSTCHECK_ENDPOINT=/api/sdwan/onboarding/postchecks
